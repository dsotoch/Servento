<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema mostrado al iniciar la app -->
    <style name="LaunchTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Tema principal de la aplicación (Stripe requiere esto) -->
    <style name="NormalTheme" parent="@style/Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

</resources>
